PORT=5000

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-db-password
PGDATABASE=medical

# Must be at least 32 characters — the server refuses to boot otherwise.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_EXPIRES_IN=24h

# Email verification (optional). Leave SMTP_USER empty to log links to console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

CLIENT_URL=http://localhost:5173

# Claude AI Health Assistant — get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key
