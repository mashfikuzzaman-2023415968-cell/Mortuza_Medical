PORT=5000

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-db-password
PGDATABASE=medical

JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# Email verification (optional). Leave SMTP_USER empty to log links to console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

CLIENT_URL=http://localhost:5173

# Gemini AI Health Assistant — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
